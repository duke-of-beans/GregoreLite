# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# GREGORE-specific
# Database
data/
*.db
*.db-shm
*.db-wal

# Redis dumps
dump.rdb

# Tauri build artifacts
src-tauri/target/

# Tauri updater signing keys (NEVER commit private key)
src-tauri/.keys/

# Test output files
test-output.txt
test-cost.txt
test_output.txt
