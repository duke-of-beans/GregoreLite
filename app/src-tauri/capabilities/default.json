{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default GregLite capabilities — grants shell access for the API sidecar",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "greglite-server",
          "sidecar": true
        }
      ]
    }
  ]
}
